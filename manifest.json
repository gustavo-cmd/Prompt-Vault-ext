{
  "manifest_version": 3,
  "name": "PromptVault",
  "version": "1.0.1",
  "description": "Salve, organize, busque e copie seus prompts de IA rapidamente com suporte a variáveis.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "options_page": "dashboard.html",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
